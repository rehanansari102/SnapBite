PORT=3005
NODE_ENV=development
SERVICE_NAME=order-service

# Databases
MONGODB_URI="mongodb://localhost:27018/snapbite_orders?replicaSet=rs0&directConnection=true"
REDIS_URL="redis://localhost:6379"

# Stripe (test keys)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Internal services
RESTAURANT_SERVICE_URL="http://localhost:3003"
AUTH_SERVICE_URL="http://localhost:3001"

# Email (Brevo)
BREVO_API_KEY="xkeysib-..."
BREVO_FROM_EMAIL="you@example.com"

# Platform
PLATFORM_FEE_PERCENT=10

# WebSocket / real-time tracking
# Must match the frontend origin or Socket.IO connections are blocked by CORS.
CORS_ORIGIN="http://localhost:3010"
# Must match the secret used by auth-service to sign JWTs, or WebSocket auth fails
# silently (driver location events get dropped).
JWT_SECRET="change-me-in-production"
